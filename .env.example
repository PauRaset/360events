# ─────────────────────────────────────────────────────────────
# 360Events.cat · Variables d'entorn (futures fases)
# Copia aquest fitxer a .env.local i omple els valors quan calgui.
# A la Fase 1 cap d'aquestes variables és necessària per arrencar.
# ─────────────────────────────────────────────────────────────

# Base de dades (Fase 2 · Prisma)
DATABASE_URL=

# Enviament d'emails (Resend)
RESEND_API_KEY=

# Trucades / SMS (Twilio)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_NUMBER=

# Google Calendar (sincronització d'esdeveniments)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
