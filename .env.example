# ─────────────────────────────────────────────────────────────
# 360Events.cat · Variables d'entorn
# Copia aquest fitxer a .env i omple els valors.
# ─────────────────────────────────────────────────────────────

# Base de dades · PostgreSQL (Prisma)
# Connexió a Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Enviament d'emails (Resend) — necessari per rebre les reserves per email.
# Si es deixa buit, les reserves es desen igualment a la BD (només s'omet l'email).
RESEND_API_KEY=
# Remitent dels emails. Per defecte "onboarding@resend.dev" (domini de proves de Resend).
RESEND_FROM="onboarding@resend.dev"

# Trucades / SMS (Twilio)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_NUMBER=

# Google Calendar (sincronització d'esdeveniments)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
